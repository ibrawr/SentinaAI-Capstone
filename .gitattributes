# Enforce LF line endings for shell scripts and Python — these break in WSL/Linux
# if checked out with CRLF (Windows default).
*.sh        text eol=lf
*.py        text eol=lf
*.conf      text eol=lf

# Windows-specific files keep CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line-ending conversion
*.crt       binary
*.key       binary
*.der       binary
*.p12       binary
*.png       binary
*.jpg       binary
*.ico       binary
